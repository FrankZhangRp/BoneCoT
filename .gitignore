# Ignore Mac OS specific files
.DS_Store

# Ignore Python compiled files
*.pyc

# Ignore Python cache directories
__pycache__/
.ipynb_checkpoints/

# Ignore generated outputs
finetune_logs/

# Keep model weights out of GitHub; publish large checkpoints through Hugging Face.
finetune/checkpoints/*
!finetune/checkpoints/.gitkeep
*.pth
*.pt
*.ckpt
*.safetensors
*.onnx
*.zip
